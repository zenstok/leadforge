# === LeadForge Configuration ===

# Bright Data (web scraping)
BRIGHTDATA_API_TOKEN=brightdata-api-token

# TokenRouter / Qwen Cloud (LLM)
TOKENROUTER_API_KEY=sk-tokenrouter-api-key
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
# Use provider/model format for TokenRouter (e.g., deepseek/deepseek-v4-pro, openai/gpt-5.5)
QWEN_MODEL=deepseek/deepseek-v4-pro

# Evermind (agent memory)
EVERMIND_API_URL=http://localhost:1995/api/v1
EVERMIND_API_KEY=your_evermind_key

# App settings
PORT=8000
HOST=0.0.0.0
